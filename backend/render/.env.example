# Copy to .env for local development. Never commit .env.

# Required — get from https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...

# Optional overrides
PIIS_MODEL=claude-sonnet-4-6
PIIS_MAX_SEARCHES=6

# Restrict CORS to your frontend origin in production. Comma-separate multiple.
# CORS_ORIGIN=https://piis.vercel.app
CORS_ORIGIN=*

# Local port
PORT=3000
